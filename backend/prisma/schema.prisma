// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  SUPERVISOR
  ADMIN
}

enum SupervisorStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum DoctorStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum SlotStatus {
  OPEN
  BOOKED
  CANCELLED
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PerformanceEventType {
  REPORT_SUBMITTED
  NO_SHOW
  CANCEL_DOCTOR
  CANCEL_PATIENT
  REJECTED
}

model User {
  id                 String             @id @default(uuid())
  email              String?            @unique
  phone              String?            @unique
  username           String             @unique
  password           String
  name               String
  doctorIdNumber     String?            @unique
  age                Int?
  gender             String?
  avatar             String?
  role               Role               @default(PATIENT)
  supervisorStatus   SupervisorStatus   @default(NONE)
  doctorStatus       DoctorStatus       @default(NONE)
  blocked            Boolean            @default(false)
  supervisorRequests SupervisorRequest[] @relation("Applicant")
  supervisorDecisions SupervisorRequest[] @relation("Reviewer")
  doctorRequests     DoctorRequest[]    @relation("DoctorApplicant")
  doctorDecisions    DoctorRequest[]    @relation("DoctorReviewer")
  notifications      Notification[]     @relation("Recipient")
  availabilitySlots  AvailabilitySlot[]
  appointmentsAsDoctor  Appointment[]   @relation("AppointmentDoctor")
  appointmentsAsPatient Appointment[]   @relation("AppointmentPatient")
  conversations      ConversationParticipant[]
  messagesSent       Message[]          @relation("MessagesSent")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model SupervisorRequest {
  id          String           @id @default(uuid())
  applicant   User             @relation("Applicant", fields: [applicantId], references: [id])
  applicantId String
  reviewer    User?            @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewerId  String?
  status      SupervisorStatus @default(PENDING)
  note        String?
  createdAt   DateTime         @default(now())
  decidedAt   DateTime?
}

model DoctorRequest {
  id          String        @id @default(uuid())
  applicant   User          @relation("DoctorApplicant", fields: [applicantId], references: [id])
  applicantId String
  reviewer    User?         @relation("DoctorReviewer", fields: [reviewerId], references: [id])
  reviewerId  String?
  status      DoctorStatus  @default(PENDING)
  note        String?
  createdAt   DateTime      @default(now())
  decidedAt   DateTime?
}

model Notification {
  id          String   @id @default(uuid())
  title       String
  body        String
  read        Boolean  @default(false)
  recipient   User     @relation("Recipient", fields: [recipientId], references: [id])
  recipientId String
  createdAt   DateTime @default(now())
}

model AvailabilitySlot {
  id        String      @id @default(uuid())
  doctor    User        @relation(fields: [doctorId], references: [id])
  doctorId  String
  startTime DateTime
  endTime   DateTime
  purpose   String      @default("General")
  status    SlotStatus  @default(OPEN)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  appointment Appointment?

  @@index([doctorId, startTime])
}

model Appointment {
  id         String            @id @default(uuid())
  slot       AvailabilitySlot  @relation(fields: [slotId], references: [id])
  slotId     String            @unique
  doctor     User              @relation("AppointmentDoctor", fields: [doctorId], references: [id])
  doctorId   String
  doctorPhone String?
  patient    User              @relation("AppointmentPatient", fields: [patientId], references: [id])
  patientId  String
  status     AppointmentStatus @default(PENDING)
  note       String?
  reportSubmitted   Boolean    @default(false)
  reportSubmittedAt DateTime?
  noShow            Boolean    @default(false)
  cancelledByDoctor Boolean    @default(false)
  cancelledByPatient Boolean   @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([doctorId])
  @@index([patientId])
}

model AppointmentEvent {
  id            String                @id @default(uuid())
  appointmentId String?
  doctorId      String
  patientId     String?
  type          PerformanceEventType
  createdAt     DateTime              @default(now())

  @@index([doctorId, createdAt])
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]
  participants ConversationParticipant[]
}

model ConversationParticipant {
  id              String   @id @default(uuid())
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  conversationId  String
  user            User      @relation(fields: [userId], references: [id])
  userId          String
  lastReadAt      DateTime? 

  @@unique([conversationId, userId])
}

model Message {
  id             String        @id @default(uuid())
  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  conversationId String
  sender         User          @relation("MessagesSent", fields: [senderId], references: [id])
  senderId       String
  text           String?
  imageUrl       String?
  createdAt      DateTime      @default(now())
}
